# Базовый URL для API - если пусто, используются относительные пути (/api),
# то есть запросы идут на тот же домен, что и фронтенд.
VITE_API_URL=""

# Zitadel OIDC
VITE_OIDC_AUTHORITY=http://localhost:8080
# Client ID: Zitadel Console -> Applications -> User Agent (PKCE, no secret)
VITE_OIDC_CLIENT_ID=<zitadel-spa-client-id>
VITE_OIDC_REDIRECT_URI=http://localhost:8080/callback

#LiveKit signaling WebSocket (через прокси nginx по адресу /livekit/)
VITE_LIVEKIT_URL=ws://localhost:8080/livekit

VITE_USE_AUTH_MOCK=false
