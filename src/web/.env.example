# API base URL — пустая строка = относительные пути (same-origin через nginx)
# В dev с vite proxy оставить пустым; при прямом доступе: http://localhost:8080
VITE_API_URL=

# Zitadel OIDC
VITE_OIDC_AUTHORITY=http://localhost:8080
# Client ID создаётся в Zitadel Console → Applications → User Agent (PKCE, no secret)
VITE_OIDC_CLIENT_ID=<your-zitadel-spa-client-id>
VITE_OIDC_REDIRECT_URI=http://localhost:8080/callback

# LiveKit — сигнальный WebSocket через nginx
# nginx проксирует /livekit → livekit:7880 (UDP media идёт напрямую на 50000-50200)
VITE_LIVEKIT_URL=ws://localhost:8080/livekit

# Мок-режим авторизации (только для разработки без Zitadel)
VITE_USE_AUTH_MOCK=false
