// NexTalk DB schema for dbdiagram.io
// Источник: EF Core миграции (см. docs/schema.md).
// Импорт: https://dbdiagram.io/d → New → Import → DBML → paste this file.

Project NexTalk {
  database_type: 'PostgreSQL'
  Note: '''
    Бизнес-БД `nextalk` с двумя схемами:
    - guild     — Guild Service (5 таблиц, hard-FK + cascade)
    - messaging — Messaging Service (3 таблицы, без hard-FK)
    Zitadel пользует отдельную БД `zitadel`, поэтому связи на sub — без FK.
  '''
}

// ─── Schema: guild ────────────────────────────────────────────────────────

Table guild.guilds {
  Id          uuid          [pk]
  Name        varchar(100)  [not null]
  DisplayName varchar(200)  [not null]
  OwnerId     uuid          [not null, note: 'Zitadel sub']
  CreatedAt   timestamptz   [not null]
}

Table guild.channels {
  Id        uuid         [pk]
  GuildId   uuid         [not null, ref: > guild.guilds.Id]
  Name      varchar(100) [not null]
  Type      varchar(20)  [not null, default: 'text', note: 'text|voice']
  CreatedAt timestamptz  [not null]

  Indexes {
    GuildId [name: 'IX_channels_GuildId']
  }
}

Table guild.members {
  Id          uuid         [pk]
  GuildId     uuid         [not null, ref: > guild.guilds.Id]
  UserId      uuid         [not null, note: 'Zitadel sub']
  DisplayName varchar(200) [not null]
  Username    varchar(100) [not null]
  Role        text         [not null, note: 'Member|Admin|Owner']
  JoinedAt    timestamptz  [not null]

  Indexes {
    (GuildId, UserId) [unique, name: 'IX_members_GuildId_UserId']
  }
}

Table guild.invites {
  Id        uuid         [pk]
  GuildId   uuid         [not null, ref: > guild.guilds.Id]
  Code      varchar(20)  [not null, note: 'public invite code']
  CreatedBy uuid         [not null, note: 'Zitadel sub']
  ExpiresAt timestamptz  [null, note: 'NULL = бессрочно']
  MaxUses   integer      [null, note: 'NULL = без лимита']
  UsesCount integer      [not null]
  CreatedAt timestamptz  [not null]

  Indexes {
    Code [unique, name: 'IX_invites_Code']
    GuildId [name: 'IX_invites_GuildId']
  }
}

Table guild.bans {
  Id        uuid        [pk]
  GuildId   uuid        [not null, ref: > guild.guilds.Id]
  UserId    uuid        [not null, note: 'Zitadel sub']
  BannedBy  uuid        [not null, note: 'Zitadel sub']
  BannedAt  timestamptz [not null]

  Indexes {
    (GuildId, UserId) [unique, name: 'IX_bans_GuildId_UserId']
  }
}

// ─── Schema: messaging ────────────────────────────────────────────────────
// Hard-FK на guild.* НЕТ: кросс-схемная развязка между микросервисами.

Table messaging.Messages {
  Id         uuid          [pk]
  ChannelId  uuid          [not null, note: 'soft-FK guild.channels.Id']
  GuildId    uuid          [not null, note: 'soft-FK guild.guilds.Id (денормализация для broadcast)']
  AuthorId   uuid          [not null, note: 'Zitadel sub']
  AuthorName varchar(100)  [not null, note: 'snapshot имени']
  Content    varchar(4000) [not null]
  CreatedAt  timestamptz   [not null]

  Indexes {
    (ChannelId, CreatedAt) [name: 'IX_Messages_ChannelId_CreatedAt']
  }
}

Table messaging.OutboxEvents {
  Id          uuid         [pk]
  EventType   varchar(100) [not null, note: 'message.created|deleted|...']
  GuildId     uuid         [not null, note: 'soft-FK; broadcast routing']
  Payload     text         [not null, note: 'JSON']
  PublishedAt timestamptz  [null, note: 'pickup-mark от OutboxWorker']
  Processed   boolean      [not null]
  ProcessedAt timestamptz  [null]
  CreatedAt   timestamptz  [not null]

  Indexes {
    (Processed, PublishedAt, CreatedAt) [name: 'IX_OutboxEvents_Processed_PublishedAt_CreatedAt']
  }
}

Table messaging.IdempotencyKeys {
  Key       varchar(128) [pk, note: 'X-Idempotency-Key UUID']
  Response  text         [not null, note: 'cached body']
  CreatedAt timestamptz  [not null]
  ExpiresAt timestamptz  [not null, note: 'TTL 24h']
}

// ─── Soft-связи через приложение (без FK на уровне БД) ────────────────────
// dbdiagram отрисует пунктиром при ref:
Ref soft_messages_channel: messaging.Messages.ChannelId > guild.channels.Id
Ref soft_messages_guild:   messaging.Messages.GuildId   > guild.guilds.Id
Ref soft_outbox_guild:     messaging.OutboxEvents.GuildId > guild.guilds.Id

TableGroup guild {
  guild.guilds
  guild.channels
  guild.members
  guild.invites
  guild.bans
}

TableGroup messaging {
  messaging.Messages
  messaging.OutboxEvents
  messaging.IdempotencyKeys
}
