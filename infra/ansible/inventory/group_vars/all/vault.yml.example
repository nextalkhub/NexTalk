---
# Шаблон секретов. Скопируй в vault.yml, заполни и зашифруй:
#   cp inventory/group_vars/vault.yml.example inventory/group_vars/vault.yml
#   # вписать значения
#   ansible-vault encrypt inventory/group_vars/vault.yml
#
# Запуск playbook'ов с vault:
#   ansible-playbook -i inventory/hosts.ini playbooks/site.yml --ask-vault-pass
#
# Или через файл с паролем (НЕ коммитить):
#   echo "<vault-password>" > ~/.ansible_vault_pass && chmod 600 ~/.ansible_vault_pass
#   export ANSIBLE_VAULT_PASSWORD_FILE=~/.ansible_vault_pass

# k3s server-token для join серверов и агентов в HA-кластер.
# openssl rand -hex 32
vault_k3s_token: "REPLACE_ME"

# PostgreSQL: один app-user (nextalk_app) на обе БД (nextalk и zitadel).
# openssl rand -base64 32
vault_postgres_password: "REPLACE_ME"

# Redis: один пароль на все БД.
# openssl rand -base64 32
vault_redis_password: "REPLACE_ME"

# Zitadel masterkey - РОВНО 32 символа, иначе start-from-init упадет.
# openssl rand -hex 16
vault_zitadel_masterkey: "REPLACE_ME_EXACTLY_32_CHARACTERS"

# LiveKit API ключ и secret.
# apiKey - короткий идентификатор. Доки рекомендуют префикс APIxxx.
# openssl rand -hex 8 → "APIxxxxxxxxxxx" (опционально вручную добавить префикс)
vault_livekit_api_key: "REPLACE_ME"
# secretKey - минимум 32 символа (256 бит). НЕ короче, доки LiveKit:
# https://docs.livekit.io/realtime/concepts/authentication/
# openssl rand -base64 32  (32 байта = 256 бит = 44 base64 символа)
vault_livekit_secret_key: "REPLACE_ME"

# Email для Let's Encrypt уведомлений (просрочка сертификата).
# Нужен только при tls.provider: letsencrypt в values.yaml.
# При tls.provider: cloudflare (default) - не используется.
vault_acme_email: "REPLACE_ME@nextalk.fun"

# k6 / chaos-тесты (playbooks/k6.yml).
# Пароль admin-пользователя Grafana (grafana.nextalk.fun).
vault_k6_grafana_password: "REPLACE_ME"
# JWT тестового пользователя для нагрузочных запросов k6.
# Получить: скопировать из DevTools → Network → заголовок Authorization: Bearer <token>.
vault_k6_test_token: "REPLACE_ME"
