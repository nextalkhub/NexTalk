---
# Только СЕКРЕТНЫЕ значения для сборки SealedSecret (см. seal-secrets.yml).
# Рендерится из vault.yml и передается в `helm template -s templates/secrets.yaml`,
# чтобы получить Secret nextalk-secrets, который затем запечатывается kubeseal.
# Файл существует только на время запечатывания, в git не коммитится.
#
# Не-секретные значения (db.host, db.redisHost, tls.email) живут в
# charts/nextalk/values.yaml - источник правды для GitOps, здесь не дублируются.
postgres:
  password: "{{ vault_postgres_password }}"
db:
  redisPassword: "{{ vault_redis_password }}"
livekit:
  apiKey: "{{ vault_livekit_api_key }}"
  secretKey: "{{ vault_livekit_secret_key }}"
zitadel:
  masterkey: "{{ vault_zitadel_masterkey }}"
