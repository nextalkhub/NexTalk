---
# Рендерится из vault.yml и inventory перед `helm install` (см. helm-deploy.yml).
# Подкатывается к чарту вторым -f, перебивая дефолты в values.yaml.
# Файл существует только на CI-runner'е, не коммитится.
postgres:
  password: "{{ vault_postgres_password }}"
db:
  host: "{{ hostvars['db-vps'].ansible_host }}"
  redisHost: "{{ hostvars['db-vps'].ansible_host }}"
  redisPassword: "{{ vault_redis_password }}"
livekit:
  apiKey: "{{ vault_livekit_api_key }}"
  secretKey: "{{ vault_livekit_secret_key }}"
zitadel:
  masterkey: "{{ vault_zitadel_masterkey }}"
{% if tls_provider == "letsencrypt" %}
tls:
  email: "{{ tls_email }}"
{% endif %}
