# Управляется Ansible. Ручные правки будут перезаписаны.
global
    log /dev/log local0
    log /dev/log local1 notice
    chroot /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 level admin expose-fd listeners
    stats timeout 30s
    user haproxy
    group haproxy
    daemon
    maxconn 4096

defaults
    log     global
    mode    tcp
    option  tcplog
    option  dontlognull
    timeout connect  5s
    # Длинные таймауты: kubectl watch-запросы держат соединение открытым.
    timeout client   1m
    timeout server   1m
    timeout check    5s

frontend k3s-apiserver
    bind *:6443
    default_backend k3s-cp

backend k3s-cp
    balance roundrobin
    option  tcp-check
{% for host in groups['control_plane'] %}
    server {{ host }} {{ hostvars[host]['ansible_host'] }}:6443 check inter 5s rise 2 fall 3
{% endfor %}

# Страница статистики — только из приватной сети.
listen stats
    bind *:{{ haproxy_stats_port }}
    mode http
    stats enable
    stats uri /
    stats refresh 10s
    stats show-legends
    stats show-node
