# pg_hba.conf — управляется Ansible.
# Документация: https://www.postgresql.org/docs/current/auth-pg-hba-conf.html

# --- Локальные подключения ---
local   all   postgres                          peer
local   all   prometheus                        peer
local   all   all                               peer

# --- Сервисные пользователи только из приватной сети ---
{% for host in postgres_allowed_hosts %}
{% for user in postgres_users %}
host    all   {{ user.name }}   {{ host }}   scram-sha-256
{% endfor %}
{% endfor %}

# --- Всё остальное запрещено ---
host    all   all   0.0.0.0/0   reject
host    all   all   ::/0        reject
