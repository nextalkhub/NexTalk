#
# docker-compose для observability-vps — управляется Ansible.
# Прометей/Loki/Tempo с retention под 40 GB диск.
#
# Порты публикуются на all interfaces, но защищены ufw
# (см. inventory/group_vars/observability.yml).
#


networks:
  observability:
    driver: bridge

volumes:
  prometheus-data:
  loki-data:
  tempo-data:
  grafana-data:

services:
  prometheus:
    image: "prom/prometheus:{{ observability_prometheus_version }}"
    restart: unless-stopped
    command:
      - "--config.file=/etc/prometheus/prometheus.yml"
      - "--storage.tsdb.path=/prometheus"
      - "--storage.tsdb.retention.time={{ prometheus_retention }}"
      - "--web.enable-lifecycle"
      - "--web.enable-remote-write-receiver"
    volumes:
      - ./prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - prometheus-data:/prometheus
    ports:
      - "9090:9090"
    networks: [observability]

  loki:
    image: "grafana/loki:{{ observability_loki_version }}"
    restart: unless-stopped
    command: ["-config.file=/etc/loki/loki-config.yaml", "-config.expand-env=true"]
    volumes:
      - ./loki/loki-config.yaml:/etc/loki/loki-config.yaml:ro
      - loki-data:/loki
    environment:
      - LOKI_RETENTION_PERIOD={{ loki_retention_period }}
    ports:
      - "3100:3100"
    networks: [observability]

  tempo:
    image: "grafana/tempo:{{ observability_tempo_version }}"
    restart: unless-stopped
    command: ["-config.file=/etc/tempo/tempo.yaml"]
    volumes:
      - ./tempo/tempo.yaml:/etc/tempo/tempo.yaml:ro
      - tempo-data:/var/tempo
    environment:
      - TEMPO_RETENTION={{ tempo_retention_period }}
    ports:
      - "4317:4317"   # OTLP gRPC
      - "4318:4318"   # OTLP HTTP
      - "3200:3200"   # Tempo HTTP
    networks: [observability]

  grafana:
    image: "grafana/grafana:{{ observability_grafana_version }}"
    restart: unless-stopped
    volumes:
      - ./grafana/provisioning:/etc/grafana/provisioning:ro
      - grafana-data:/var/lib/grafana
    environment:
      - GF_SERVER_ROOT_URL=https://grafana.nextalk.fun
      - GF_AUTH_ANONYMOUS_ENABLED=false
    ports:
      - "3000:3000"
    networks: [observability]
