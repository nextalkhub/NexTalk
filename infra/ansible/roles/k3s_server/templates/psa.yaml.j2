#
# PodSecurity AdmissionConfiguration для k3s.
# Документация:
#   https://kubernetes.io/docs/tasks/configure-pod-container/enforce-standards-admission-controller/
#   https://kubernetes.io/docs/concepts/security/pod-security-admission/
#
# По умолчанию ВСЕМ namespace'ам присваивается уровень "baseline" (нельзя privileged,
# нельзя hostNetwork кроме явных exemption'ов). Warn - "restricted" (нельзя root и т.п.).
#
apiVersion: apiserver.config.k8s.io/v1
kind: AdmissionConfiguration
plugins:
  - name: PodSecurity
    configuration:
      apiVersion: pod-security.admission.config.k8s.io/v1
      kind: PodSecurityConfiguration
      defaults:
        enforce: "baseline"
        enforce-version: "latest"
        audit: "restricted"
        audit-version: "latest"
        warn: "restricted"
        warn-version: "latest"
      exemptions:
        usernames: []
        runtimeClasses: []
        # kube-system - k3s coredns/local-path/metrics-server.
        # ingress-nginx - hostNetwork.
        # cert-manager - webhook требует повышенных прав.
        namespaces:
          - kube-system
          - kube-public
          - kube-node-lease
          - ingress-nginx
          - cert-manager
