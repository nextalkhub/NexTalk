# Автогенерировано Ansible — не редактировать вручную.

# Cluster
NAMESPACE={{ k6_namespace }}
DOMAIN={{ k6_domain }}

# Nodes
CP1={{ k6_cp1 }}
CP2={{ k6_cp2 }}
CP3={{ k6_cp3 }}
DB_VPS={{ k6_db_vps }}
OBS_VPS={{ k6_obs_vps }}

# Endpoints
API_BASE={{ k6_api_base }}
GRAFANA_URL={{ k6_grafana_url }}
PROMETHEUS_REMOTE_WRITE={{ k6_prometheus_remote_write }}

# Grafana
GRAFANA_USER={{ k6_grafana_user }}
GRAFANA_PASSWORD={{ k6_grafana_password }}
GRAFANA_DASHBOARD_UID={{ k6_grafana_dashboard_uid }}

# k6
K6_BIN=/usr/local/bin/k6
K6_VUS_BASELINE={{ k6_vus_baseline }}
K6_VUS_SPIKE={{ k6_vus_spike }}
K6_DURATION_BASELINE={{ k6_duration_baseline }}
K6_DURATION_SPIKE={{ k6_duration_spike }}

# Timeouts (seconds)
WAIT_HEALTHY_TIMEOUT={{ k6_wait_healthy_timeout }}
WAIT_HEALTHY_INTERVAL=5

# Test user credentials
TEST_USER_ID={{ k6_test_user_id }}
TEST_TOKEN={{ k6_test_token }}

# SSH
SSH_OPTS="-o StrictHostKeyChecking=no -o ConnectTimeout=5"
SSH_USER={{ k6_ssh_user }}
