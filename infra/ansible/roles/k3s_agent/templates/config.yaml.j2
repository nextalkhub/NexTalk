#
# k3s agent config - управляется Ansible.
#

token: "{{ k3s_token }}"
server: "https://{{ k3s_api_endpoint }}:6443"

node-ip: "{{ ansible_host }}"

# Если есть публичный IP - заявляем его как external. Полезно для
# отображения в metrics/labels и для прямого доступа к ноде.
{% if public_ip is defined %}
node-external-ip: "{{ public_ip }}"
{% endif %}

flannel-iface: "{{ private_iface }}"
